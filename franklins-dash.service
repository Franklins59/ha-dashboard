[Unit]
Description=franklins-dash Web UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/franklins-dash
ExecStart=/home/YOUR_USER/franklins-dash/venv/bin/python app.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
