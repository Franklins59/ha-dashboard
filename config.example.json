sudo sed -i 's/manage_etc_hosts: true/manage_etc_hosts: false/' /etc/cloud/cloud.cfg

# 3. /etc/hosts korrigieren
sudo sed -i 's/ShellyPanel/franklins-dash/g' /etc/hosts

# 4. Reboot
sudo reboot
